{
  "name": "engrammic-companion",
  "version": "0.2.1",
  "private": true,
  "description": "Engrammic Companion — org memory control plane for AI agents",
  "author": "Engrammic",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "ai.engrammic.companion",
    "productName": "Engrammic Companion",
    "copyright": "Copyright © Engrammic",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "paths.js",
      "logger.js",
      "embed-server.js",
      "companion-ui/**/*",
      "build/icon.png",
      "build/logo-transparent.png"
    ],
    "extraResources": [
      {
        "from": "staging/aabw",
        "to": "aabw",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Engrammic Companion",
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "sharp": "^0.35.3"
  }
}
