# Caddyfile
mytasco.engrammic.ai {
  handle /api/* {
    uri strip_prefix /api
    reverse_proxy gateway:8790
  }
  handle {
    root * /srv/web
    try_files {path} /index.html
    file_server
  }
}

# Also serve on IP for tunnel access
:80 {
  handle /api/* {
    uri strip_prefix /api
    reverse_proxy gateway:8790
  }
  handle {
    root * /srv/web
    try_files {path} /index.html
    file_server
  }
}
