# WorkOS (AuthKit + Directory Sync group → role mapping)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://127.0.0.1:5173/api/auth/callback
WORKOS_COOKIE_PASSWORD=
# Optional: map WorkOS group slugs to app roles (comma-separated role:group)
# WORKOS_GROUP_EXECUTIVE=org-memory-executives
# WORKOS_GROUP_MANAGER=org-memory-managers
# WORKOS_GROUP_EMPLOYEE=org-memory-employees

# Engrammic MCP (required for live graph + recall)
ENGRAMMIC_MCP_URL=https://beta.engrammic.ai/mcp/
# Auto-filled after MCP sign-in (Integrations → Connect MCP)
ENGRAMMIC_MCP_TOKEN=
# Optional WorkOS-style API key (sk_ prefix) if you have one
# ENGRAMMIC_MCP_API_KEY=

# Connector auto-ingest (Gmail) — configure via companion Sources tab
#
# Gmail — OAuth Desktop client JSON at ~/.cursor/aabw/gmail-oauth-client.json
#   or set GMAIL_CLIENT_ID + GMAIL_CLIENT_SECRET + GMAIL_REFRESH_TOKEN
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_QUERY=newer_than:30d
GMAIL_LOGIN_EMAIL=vu.le@engrammic.ai
GATEWAY_PORT=8790
WEB_PORT=5173
SESSION_SECRET=change-me-in-production

# Hindsight (RAG backend) + Gemini (chat/LLM)
GEMINI_API_KEY=your-gemini-api-key
HINDSIGHT_URL=http://localhost:8888
